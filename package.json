{
  "name": "routecard-skill",
  "version": "0.1.0",
  "description": "Local-first agent skill for planning connector route cards before external actions.",
  "type": "module",
  "bin": {
    "routecard-skill": "./bin/routecard-skill.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "build": "node scripts/check.js && node --check bin/routecard-skill.js",
    "smoke": "node bin/routecard-skill.js fixtures/action-request.json fixtures/catalog.json --format markdown",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "connector",
    "routing",
    "dry-run",
    "approval"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/routecard-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/routecard-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/routecard-skill#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "docs/",
    "fixtures/",
    "src/",
    "scripts/",
    "test/",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md"
  ]
}
